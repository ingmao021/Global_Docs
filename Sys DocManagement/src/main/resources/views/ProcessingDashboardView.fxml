<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.empresa.docprocessor.presentation.controllers.ProcessingDashboardController"
      spacing="15" prefWidth="500" prefHeight="250" stylesheets="@/views/dashboard.css">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Procesamiento por lotes" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <Label fx:id="statusLabel" text="En espera..." wrapText="true"/>
    <ProgressBar fx:id="progressBar" prefWidth="400" progress="0" maxWidth="Infinity"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="counterLabel" text="0 / 0"/>
        <Button fx:id="cancelButton" text="Cancelar lote" onAction="#onCancel" disable="true"/>
    </HBox>
</VBox>
