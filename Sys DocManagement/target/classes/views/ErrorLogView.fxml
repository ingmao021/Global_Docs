<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.empresa.docprocessor.presentation.controllers.ErrorLogController"
      spacing="15" prefWidth="700" prefHeight="500" stylesheets="@/views/errorlog.css">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Log de errores" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Buscar por archivo:"/>
        <TextField fx:id="searchTextField" prefWidth="250" promptText="Nombre del archivo"/>
        <Button text="Limpiar log de sesión" onAction="#onClearLog"/>
    </HBox>
    <TableView fx:id="errorsTableView" VBox.vgrow="ALWAYS" prefHeight="350">
        <columns>
            <TableColumn fx:id="colFile" text="Archivo" prefWidth="200"/>
            <TableColumn fx:id="colCountry" text="País" prefWidth="100"/>
            <TableColumn fx:id="colType" text="Tipo" prefWidth="140"/>
            <TableColumn fx:id="colDetail" text="Detalle" prefWidth="240"/>
        </columns>
    </TableView>
</VBox>
