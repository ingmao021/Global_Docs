<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.empresa.docprocessor.presentation.controllers.DocumentUploadController"
      spacing="15" prefWidth="700" prefHeight="500" stylesheets="@/views/upload.css">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Carga de documentos" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Tipo de documento:"/>
        <ComboBox fx:id="documentTypeComboBox" prefWidth="220" promptText="Tipo"/>
        <Button text="Seleccionar archivos" onAction="#onSelectFiles"/>
        <Button text="Carga masiva (carpeta)" onAction="#onSelectFolder"/>
        <Button text="Cargar datos de prueba (25 archivos)" onAction="#onLoadSampleData"/>
        <Button text="Procesar lote" onAction="#onProcessBatch"/>
    </HBox>
    <Label text="Zona de arrastre o use los botones. Vista previa:"/>
    <TableView fx:id="filesTableView" VBox.vgrow="ALWAYS" prefHeight="300">
        <columns>
            <TableColumn fx:id="fileNameColumn" text="Archivo" prefWidth="300"/>
            <TableColumn fx:id="sizeColumn" text="Tamaño" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
